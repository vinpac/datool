{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["bun-types", "node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/client/*"]
    }
  },
  "include": ["src", "tests"],
  "exclude": [
    "src/client/components/event-list-view.tsx",
    "src/client/components/hook-actions.tsx",
    "src/client/components/index.d.ts",
    "src/client/components/index.ts",
    "src/client/components/run-trace-view.tsx",
    "src/client/components/stream-viewer.tsx",
    "src/client/components/workflow-trace-view.tsx",
    "src/client/components/workflow-traces/**/*",
    "src/client/lib/trace-builder.ts",
    "src/client/lib/trace-utils.ts"
  ]
}
