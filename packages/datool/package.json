{
  "name": "datool",
  "version": "0.0.24",
  "type": "module",
  "description": "Local-only config-driven log viewer with SSE streaming and a generic table UI.",
  "bin": {
    "datool": "./dist/node/cli.js"
  },
  "types": "./dist/browser.d.ts",
  "exports": {
    ".": {
      "types": "./dist/browser.d.ts",
      "browser": "./dist/browser.js",
      "react-server": "./dist/browser.js",
      "node": "./dist/index.js",
      "default": "./dist/browser.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "default": "./dist/next/index.js"
    },
    "./next/server": {
      "types": "./dist/next/server.d.ts",
      "default": "./dist/next/server.js"
    },
    "./page": {
      "types": "./dist/client/public.d.ts",
      "default": "./dist/client/public.js"
    },
    "./next/styles.css": "./dist/client/index.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "bun run typecheck && bun run build:runtime && bun run build:types",
    "build:runtime": "bun run scripts/build-runtime.ts",
    "build:types": "tsc -p tsconfig.types.json",
    "prepare": "bun run build",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit",
    "test:e2e": "bun test tests/packaged-consumer.test.ts",
    "test": "bun test",
    "lint": "eslint src tests --ext .ts,.tsx"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-document": "^3.20.4",
    "@tiptap/extension-paragraph": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-text": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.14",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.0.0",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.2.22",
    "esbuild": "^0.27.4"
  }
}
