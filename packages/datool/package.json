{
  "name": "datool",
  "version": "0.0.4",
  "type": "module",
  "description": "Local-only config-driven log viewer with SSE streaming and a generic table UI.",
  "bin": {
    "datool": "./src/node/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "client-dist",
    "index.html",
    "README.md"
  ],
  "scripts": {
    "build": "bun run build:client && bun run typecheck",
    "build:client": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "bun run build:client && bun test",
    "lint": "eslint src tests --ext .ts,.tsx"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-document": "^3.20.4",
    "@tiptap/extension-paragraph": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-text": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.2.22"
  }
}
