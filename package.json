{
  "name": "datool",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.2.22",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "bun run build:registry && vite build",
    "build:package": "bun run --filter datool build",
    "build:registry": "shadcn build",
    "typecheck": "tsc -p tsconfig.app.json && bun run --filter datool typecheck",
    "test": "bun run --filter datool test",
    "test:e2e": "bun run --filter datool test:e2e",
    "lint": "bun run --filter datool lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json}\""
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.0.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1"
  }
}
